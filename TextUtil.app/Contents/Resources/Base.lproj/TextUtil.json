{
  "type": "NavigationSplitView",
  "id": 100,
  "properties": {
    "columnVisibility": "all",
    "style": "balanced",
    "frame": {
      "minWidth": 800,
      "minHeight": 540
    },
    "padding": {
      "top": 4,
    }
  },
  "sidebar": {
    "type": "VStack",
    "properties": {
      "spacing": 8,
      "navigationSplitViewColumnWidth": {
        "min": 220,
        "ideal": 320,
        "max": 360
      }
    },
    "children": [
      {
        "type": "Table",
        "id": 10,
        "properties": {
          "columns": ["Document"],
          "widths": [280],
          "actionID": "textutil.files.selection.changed",
          "doubleClickActionID": "textutil.files.double.click",
        }
      },
      {
        "type": "HStack",
        "properties": {
          "spacing": 0
        },
        "children": [
          {
            "type": "Button",
            "id": 101,
            "properties": {
              "systemImage": "plus.circle",
              "imageScale": "large",
              "buttonStyle": "plain",
              "actionID": "textutil.add.files",
              "frame": {
                "width": 32,
                "height": 32
              }
            }
          },
          {
            "type": "Button",
            "id": 102,
            "properties": {
              "systemImage": "minus.circle",
              "imageScale": "large",
              "buttonStyle": "plain",
              "actionID": "textutil.remove.selected",
              "disabled": true,
              "frame": {
                "width": 32,
                "height": 32
              }
            }
          },
          {
            "type": "Divider",
            "properties": {
              "padding": {
                "top": 0,
                "leading": 8,
                "bottom": 0,
                "trailing": 8
              },
              "frame": {
                "height": 16
              }
            }
          },
          {
            "type": "Button",
            "id": 105,
            "properties": {
              "systemImage": "eye",
              "imageScale": "medium",
              "buttonStyle": "plain",
              "actionID": "textutil.quicklook",
              "disabled": true,
              "frame": {
                "width": 32,
                "height": 32
              }
            }
          },
          {
            "type": "Button",
            "id": 104,
            "properties": {
              "systemImage": "finder",
              "imageScale": "medium",
              "buttonStyle": "plain",
              "actionID": "textutil.reveal.in.finder",
              "disabled": true,
              "frame": {
                "width": 32,
                "height": 32
              }
            }
          },
          {
            "type": "Spacer"
          },
          {
            "type": "Button",
            "id": 103,
            "properties": {
              "systemImage": "trash.circle",
              "imageScale": "large",
              "buttonStyle": "plain",
              "actionID": "textutil.clear.all",
              "frame": {
                "width": 32,
                "height": 32
              }
            }
          }
        ]
      }
    ]
  },
  "detail": {
    "type": "VStack",
    "properties": {
      "frame": {
        "minWidth": 420,
        "idealWidth": 460
      },
      "spacing": 16,
      "padding": "default"
