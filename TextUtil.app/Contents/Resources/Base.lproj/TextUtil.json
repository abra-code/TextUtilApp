    "children": [
      {
        "type": "GroupBox",
        "properties": {
          "title": "Info",
          "frame": {
            "minWidth": 400
          }
        },
        "children": [
          {
            "type": "ScrollView",
            "properties": {
              "frame": {
                "minWidth": 390,
                "minHeight": 200
              }
            },
            "content": {
              "type": "Text",
              "id": 12,
              "properties": {
                "text": "",
                "frame": {
                "minWidth": 380,
                },
                "foregroundStyle": "secondary",
              }
            }
          },
          { "type": "Divider", "properties": { "opacity": 0, "frame": { "height": 0 } } }
        ]
      },
      {
        "type": "GroupBox",
        "properties": {
          "title": "Conversion Options",
          "frame": {
            "minWidth": 400,
          }
        },
        "children": [
          {
            "type": "VStack",
            "properties": {
              "spacing": 14,
              "alignment": "leading",
              "padding": "default",
              "frame": {
                "minWidth": 390,
                "idealWidth": 390
              }
            },
            "children": [
              {
                "type": "Picker",
                "id": 13,
                "properties": {
                  "title": "Output Format",
                  "options": [
                    {"title": "Plain Text - txt", "tag": "txt"},
                    {"title": "Rich Text Format - rtf", "tag": "rtf"},
                    {"title": "Rich Text With Images - rtfd", "tag": "rtfd"},
                    {"title": "Microsoft Word - docx", "tag": "docx"},
                    {"title": "Microsoft Word Legacy - doc", "tag": "doc"},
                    {"title": "Microsoft Word XML - wordml", "tag": "wordml"},
                    {"title": "OpenDocument Text - odt", "tag": "odt"},
                    {"title": "Web Page - html", "tag": "html"},
                    {"title": "Safari Web Archive - webarchive", "tag": "webarchive"}
                  ],
                  "actionID": "textutil.format.changed"
                }
              },
              {
                "type": "Toggle",
                "id": 15,
                "properties": {
                  "title": "Don't copy metadata (author, subject, etc.)"
                }
              },
              { "type": "Divider", "properties": { "opacity": 0, "frame": { "height": 0 } } }
            ]
          }
        ]
      },
      {
        "type": "Spacer",
      },
      {
        "type": "HStack",
        "properties": {
          "spacing": 16
        },
        "children": [
         {
         	"type": "Toggle",
            "id": 14,
            "properties": {
                "title": "Overwrite existing files"
            }
         },
         {
          "type": "Spacer"
         },
         {
           "type": "Button",
           "properties": {
             "title": "Convert",
             "buttonStyle": "borderedProminent",
             "actionID": "textutil.start.batch"
           }
         }
       ]
     }
    ]
  }
}
